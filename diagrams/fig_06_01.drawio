      <mxGeometry x="400" y="300" width="220" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="rank" value="向量相似度排序&#xa;在候选集内做 HNSW 检索（距离升序）" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="200" y="430" width="300" height="80" as="geometry"/>
