<?xml version="1.0" encoding="UTF-8"?>
<mxGraphModel pageWidth="700" pageHeight="640" grid="1" gridSize="10">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>
    <mxCell id="user" value="用户输入&#xa;自然语言查询 + 业务约束" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="270" y="40" width="160" height="60" as="geometry"/>
    </mxCell>
    <mxCell id="meta_ch" value="元数据通道&#xa;where 硬性约束过滤" style="rounded=1;whiteSpace=wrap;fillColor=#E8F4FD;strokeColor=#4A4A4A;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="80" y="180" width="220" height="70" as="geometry"/>
    </mxCell>
    <mxCell id="vec_ch" value="向量通道&#xa;查询文本 → 嵌入向量" style="rounded=1;whiteSpace=wrap;fillColor=#E8F4FD;strokeColor=#4A4A4A;fontColor=#333333;fontSize=12;" vertex="1" parent="1">
      <mxGeometry x="400" y="180" width="220" height="70" as="geometry"/>
